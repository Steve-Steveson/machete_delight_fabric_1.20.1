			"net.steveson.machetedelight.MacheteDelightMod"
		],
		"fabric-datagen": [
			"net.steveson.machetedelight.MacheteDelightDataGenerator"
		]
	},
	"mixins": [
      "machete_delight.mixins.json"
	],
	"depends": {
